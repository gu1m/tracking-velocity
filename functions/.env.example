# ── Mercado Pago ─────────────────────────────────────────────────────────────
# Produção: APP_USR-... | Sandbox: TEST-...
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID do preapproval_plan (criado com: node scripts/create_mp_plan.js)
MP_PLAN_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_BACK_URL=https://seuapp.com/subscription/callback
# Chave secreta do webhook: Painel MP → Integrações → Webhooks
MP_WEBHOOK_SECRET=

# ── Firebase Admin ────────────────────────────────────────────────────────────
# JSON completo da Service Account (uma linha só, sem quebras)
# Console Firebase → Configurações → Contas de serviço → Gerar nova chave
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Supabase ──────────────────────────────────────────────────────────────────
# Painel Supabase → Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
# ATENÇÃO: service_role bypassa RLS — nunca exponha no app Flutter
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
